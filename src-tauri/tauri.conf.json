{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hyacinth",
  "version": "0.1.0",
  "identifier": "com.hyacinth.chat",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Hyacinth",
        "width": 1100,
        "height": 760,
        "minWidth": 360,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "android": {
      "minSdkVersion": 24
    }
  }
}
